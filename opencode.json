  "mcp": {
    "scrapling": {
      "type": "local",
      "command": ["python3", "-m", "scrapling.cli", "mcp"],
      "enabled": true,
      "timeout": 30000
    }
  },
  "permission": {
    "skill": {
      "*": "allow",
      "supabase": "allow",
      "supabase-postgres-best-practices": "allow",
      "ecc": "allow",
      "superpowers": "allow",
      "caveman*": "allow",
      "mem0*": "allow",
      "baoyu-*": "allow",
      "scrapling*": "allow",
      "ui-ux-pro-max": "allow"
    }
  }
}
